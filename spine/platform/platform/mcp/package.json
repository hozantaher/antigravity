{
  "name": "@hozan/mcp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "tsx mcp-server/index.ts --mode=http",
    "mcp": "tsx mcp-server/index.ts",
    "mcp:remote": "tsx mcp-server/index.ts --mode=http",
    "test": "vitest run --exclude 'e2e/**'",
    "test:watch": "vitest",
    "test:e2e": "vitest run e2e/",
    "docker:test": "docker-compose -f docker-compose.test.yml up -d && npm run test:e2e; docker-compose -f docker-compose.test.yml down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/node": "^10.52.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-loki": "^3.0.0",
    "typesense": "^3.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
