{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "rootDir": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["lib/**/*.ts", "scrapers/**/*.ts", "mcp-server/**/*.ts", "scripts/**/*.ts", "e2e/**/*.ts"],
  "exclude": ["node_modules"]
}
