# Mail Lab dev profile — dashboard talks to a sealed local stack instead
# of production. Use this when iterating against simulated mail providers.
#
# Workflow:
#   1. cd apps/outreach-dashboard
#   2. cp .env.lab.example .env.local
#   3. (in repo root) bash scripts/mail-lab/up.sh
#   4. (back in apps/outreach-dashboard) pnpm dev
#   5. UI on http://localhost:18175 ← BFF :3100 ← Go :8080 ← Mail Lab
#
# Full guide: docs/playbooks/mail-lab-quickstart.md
# Vite dev port matches package.json `dev` script (vite --port 18175).
#
# DON'T copy these values into a prod .env — they assume the lab stack
# is reachable on localhost and use the test-only Lab API key.

# ── Express BFF ────────────────────────────────────────────────────────
PORT=3100

# ── Go orchestrator dev (assumes you run `go run ./cmd/outreach server`
#    in services/orchestrator/, listening on :8080) ──────────────────────
GO_SERVER_URL=http://localhost:8080

# ── API key shared between BFF and Go orchestrator ─────────────────────
# Lab uses the same key for the Mail Lab admin API (LAB_API_KEY) and
# the Go orchestrator (OUTREACH_API_KEY) so the operator only has to
# remember one value. Override per service if you want strict isolation.
OUTREACH_API_KEY=lab-demo-only

# ── CORS — Vite dev server origin ──────────────────────────────────────
CORS_ORIGIN=http://localhost:18175

# ── Mail Lab admin API base ────────────────────────────────────────────
# Used by future BFF/test-harness integrations to drive lab state
# (create mailbox, inject inbound mail, set bounce profile). Today the
# dashboard does not call this directly; the var is here so test harness
# scenarios reading the same .env can pick it up. ML4.2/ML4.3 will wire
# server-side.
LAB_API_BASE=http://localhost:8090
LAB_API_KEY=lab-demo-only

# ── Mail Lab SMTP/IMAP endpoints (dashboard does not connect directly,
#    but the orchestrator picks these up via env override in dev) ───────
MAIL_LAB_SMTP_HOST=mx.seznam.lab
MAIL_LAB_SMTP_PORT=587
MAIL_LAB_IMAP_HOST=imap.seznam.lab
MAIL_LAB_IMAP_PORT=143

# ── Sentry — DISABLED in lab ──────────────────────────────────────────
# Mail Lab is sealed (no egress) and prod-only Sentry projects don't
# need lab traffic anyway. Empty values disable all telemetry shipping.
SENTRY_DSN_BFF=
VITE_SENTRY_DSN_FRONTEND=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT_FRONTEND=
