#!/usr/bin/env bash
# ===========================================================================
# .env.fastmail.example — Live-run environment template for privacy-gateway
#
# Usage:
#   cp scripts/.env.fastmail.example scripts/.env.fastmail.local
#   # Edit .env.fastmail.local with your real values
#   ./scripts/check-fastmail-env.sh scripts/.env.fastmail.local
#   ./scripts/run-live.sh
#
# Alternatively, use the interactive wizard to generate the local file:
#   ./scripts/prepare-fastmail-env.sh
#
# DO NOT commit .env.fastmail.local — it is .gitignore-protected.
# This example file is safe to commit; it contains no real secrets.
# ===========================================================================

# === REQUIRED: Fastmail account ===

# The Fastmail address that owns the alias domain (gateway sender identity).
FASTMAIL_GATEWAY_ADDRESS=your-gateway@fastmail.com

# The custom domain you have registered and pointed at Fastmail.
# If omitted, it is derived from the domain part of FASTMAIL_GATEWAY_ADDRESS.
ALIAS_DOMAIN=yourdomain.com

# The mailbox that receives forwarded alias mail during the live run.
RECIPIENT_MAILBOX_ADDRESS=test-inbox@yourdomain.com

# Fastmail app-password (Settings > Passwords > App Passwords).
# Generate a dedicated one for this service; do not reuse your account password.
SMTP_PASSWORD=your-fastmail-app-password

# === REQUIRED: Encryption ===

# 32-byte base64-encoded key used to encrypt stored alias data.
# Generate once with: openssl rand -base64 32
# Keep this value stable — changing it invalidates all stored ciphertext.
DATA_ENCRYPTION_KEY_B64=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# === Service binding ===

LISTEN_ADDR=:8080
DATA_DIR=./data

# === Delivery mode ===

# record-only  — log relays without sending (safe default / CI)
# smtp         — live SMTP delivery via Fastmail (required for live run)
DELIVERY_MODE=smtp

# === SMTP (Fastmail outbound) ===

SMTP_HOST=smtp.fastmail.com
SMTP_PORT=587
# SMTP_USERNAME defaults to FASTMAIL_GATEWAY_ADDRESS if not set explicitly.
SMTP_USERNAME=${FASTMAIL_GATEWAY_ADDRESS}
# SMTP_HELLO_DOMAIN defaults to ALIAS_DOMAIN if not set explicitly.
SMTP_HELLO_DOMAIN=${ALIAS_DOMAIN}
SMTP_REQUIRE_STARTTLS=true
SMTP_CONNECT_TIMEOUT_SECONDS=10

# === IMAP (Fastmail inbound / inbox sync) ===

IMAP_HOST=imap.fastmail.com
IMAP_PORT=993
# IMAP_USERNAME and IMAP_PASSWORD default to FASTMAIL_GATEWAY_ADDRESS / SMTP_PASSWORD.
IMAP_USERNAME=${FASTMAIL_GATEWAY_ADDRESS}
IMAP_PASSWORD=${SMTP_PASSWORD}
IMAP_TIMEOUT_SECONDS=10

# === Limits ===

MAX_RECIPIENTS=10
# 128 KiB default (131072 bytes)
MAX_MESSAGE_BYTES=131072

# === Retention (hours; all have safe defaults — override only if needed) ===

# AUDIT_RETENTION_HOURS=720          # 30 days
# IDENTITY_LINK_RETENTION_HOURS=2160 # 90 days
# SUBMISSION_RETENTION_HOURS=720     # 30 days
# INBOX_RETENTION_HOURS=720          # 30 days
# OUTBOX_RETENTION_HOURS=720         # 30 days
# IMAP_CURSOR_RETENTION_HOURS=168    # 7 days
# ALIAS_RETENTION_HOURS=2160         # 90 days
# RELAY_ATTEMPT_RETENTION_HOURS=720  # 30 days

# === Dev / test identity (used by live-run test scripts) ===

DEV_API_TOKEN=dev-token
# Leave INTAKE_API_TOKEN empty to disable the intake endpoint.
INTAKE_API_TOKEN=
DEV_USER_ID=user-dev
DEV_TENANT_ID=tenant-dev
DEV_USER_EMAIL=${FASTMAIL_GATEWAY_ADDRESS}

# intake actor (optional — falls back to DEV_TENANT_ID)
# INTAKE_USER_ID=intake-user
# INTAKE_TENANT_ID=tenant-dev
# INTAKE_USER_EMAIL=intake@example.com

# === Live-run test targets (used by postcheck / verify scripts) ===

# The gateway address used as the inbound test mailbox during IMAP checks.
INBOUND_TEST_MAILBOX_ADDRESS=${FASTMAIL_GATEWAY_ADDRESS}
