LISTEN_ADDR=:8080
ALIAS_DOMAIN=your-domain.example
DATA_DIR=./data
DATA_ENCRYPTION_KEY_B64=REPLACE_WITH_BASE64_32_BYTE_KEY

DELIVERY_MODE=smtp
SMTP_HOST=smtp.fastmail.com
SMTP_PORT=587
SMTP_USERNAME=fastmail-user@your-domain.example
SMTP_PASSWORD=REPLACE_WITH_FASTMAIL_APP_PASSWORD
SMTP_HELLO_DOMAIN=your-domain.example
SMTP_REQUIRE_STARTTLS=true
SMTP_CONNECT_TIMEOUT_SECONDS=10

IMAP_HOST=imap.fastmail.com
IMAP_PORT=993
IMAP_USERNAME=fastmail-user@your-domain.example
IMAP_PASSWORD=REPLACE_WITH_FASTMAIL_APP_PASSWORD
IMAP_TIMEOUT_SECONDS=10

MAX_RECIPIENTS=10
MAX_MESSAGE_BYTES=131072

DEV_API_TOKEN=dev-token
DEV_USER_ID=user-dev
DEV_TENANT_ID=tenant-dev
DEV_USER_EMAIL=fastmail-user@your-domain.example
