# TEMPLATE: kopíruj do services/<domain>/.env.example a nech JEN relevantní řádky.
# TEMPLATE: .env (bez .example) je gitignored. Nikdy necommituj reálné hodnoty.

# -----------------------------------------------------------------------------
# Core (obvykle potřebuje každá backend služba)
# -----------------------------------------------------------------------------

# Postgres. V dev často DB_SSL_MODE=disable, v prod require.
DATABASE_URL=postgres://user:password@localhost:5432/db_name
DB_SSL_MODE=disable

# Redis (pokud používáš fronty / cache). Railway: internal DNS.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Service auth
# -----------------------------------------------------------------------------

# API key kterým ostatní služby volají tuto (X-API-Key header).
# V prod rotovat. V dev dev-placeholder.
SERVICE_API_KEY=dev-placeholder-rotate-in-prod

# -----------------------------------------------------------------------------
# Upstream service URLs (vyplň dle dependencies v service.yaml)
# -----------------------------------------------------------------------------

# Railway internal DNS: http://<service>.railway.internal:<port>
# RELAY_URL=http://relay.railway.internal:8080
# PRIVACY_GATEWAY_URL=http://privacy-gateway.railway.internal:8080

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

LOG_LEVEL=info
SENTRY_DSN=
# TRACE_ENDPOINT=

# -----------------------------------------------------------------------------
# Service-specific (vyplň dle domény)
# -----------------------------------------------------------------------------

# <VAR_NAME>=<placeholder>
