# Local runnable config for safe non-provider testing.
# This file is suitable for alias, outbound API, persistence, and restart checks
# without any real SMTP or IMAP provider.

LISTEN_ADDR=:8081
ALIAS_DOMAIN=test.local
DATA_DIR=./data-record-only-test
DATA_ENCRYPTION_KEY_B64=L3r/Mn1I5wW5sfZBlJ0zzGU5yM1bl2HHQo1R1lIRu+k=

DELIVERY_MODE=record-only

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HELLO_DOMAIN=test.local
SMTP_REQUIRE_STARTTLS=true
SMTP_CONNECT_TIMEOUT_SECONDS=10

IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

MAX_RECIPIENTS=10
MAX_MESSAGE_BYTES=131072

DEV_API_TOKEN=dev-token
DEV_USER_ID=user-dev
DEV_TENANT_ID=tenant-dev
DEV_USER_EMAIL=user@test.local
