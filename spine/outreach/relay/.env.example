# HTTP API
PORT=8090
ADMIN_TOKEN=dev-token

# SMTP relay
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# Tor hidden service (optional)
ONION_LISTEN_ADDR=

# TLS / proxy (dev)
INSECURE_TLS=true
SOCKS_PROXY=

# Strict-geo proxy filter — drops candidates whose ISO country tag is missing
# or outside PROXY_COUNTRY_CODES. Only the geonode feed surfaces country data,
# so proxifly + proxyscrape candidates are dropped in strict mode (they have
# no geo info). Leave PROXY_STRICT_GEO unset to preserve the legacy "let probe
# decide" behaviour. Default whitelist covers Central Europe; widen if the pool
# stays empty after a few refresh cycles.
PROXY_STRICT_GEO=
PROXY_COUNTRY_CODES=CZ,SK,DE,AT,PL,HU,SI
PROXY_PREFERRED_COUNTRY=CZ

# Duress check (canary detection)
DURESS_CHECK=false
