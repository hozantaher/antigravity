# Anti-Trace Relay Secrets
# Copy to /opt/anti-trace-relay/secrets with chmod 0600
# Generate keys: head -c 32 /dev/urandom | base64

DATA_ENCRYPTION_KEY_B64=
VAULT_ENCRYPTION_KEY_B64=
DEV_API_TOKEN=
DEV_USER_ID=operator
DEV_TENANT_ID=org-1

# SMTP (when DELIVERY_MODE=smtp)
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_HELLO_DOMAIN=relay.example.com
# SMTP_REQUIRE_STARTTLS=true
