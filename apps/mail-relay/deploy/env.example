# Anti-Trace Relay Environment Configuration
# Copy to /opt/anti-trace-relay/env and customize

LISTEN_ADDR=:8090
DATA_DIR=/opt/anti-trace-relay/data
DELIVERY_MODE=record-only

# TLS (required)
TLS_CERT_FILE=/opt/anti-trace-relay/tls/cert.pem
TLS_KEY_FILE=/opt/anti-trace-relay/tls/key.pem

# Transport mode: direct, tor, vpn, vpn+tor
TRANSPORT_MODE=tor

# Timing resistance
RELAY_MIN_DELAY_SECONDS=30
RELAY_MAX_DELAY_SECONDS=300
BATCH_INTERVAL_SECONDS=60

# Abuse prevention
RATE_LIMIT_PER_MINUTE=10
MAX_ENVELOPE_BYTES=32768

# Retention (hours, 0=disabled)
AUDIT_RETENTION_HOURS=72
VAULT_RETENTION_HOURS=0
RELAY_RETENTION_HOURS=24

# Tor (when TRANSPORT_MODE=tor or vpn+tor)
TOR_ENABLED=true
TOR_SOCKS_PORT=9050
TOR_HIDDEN_PORT=80
ONION_LISTEN_ADDR=127.0.0.1:8091
