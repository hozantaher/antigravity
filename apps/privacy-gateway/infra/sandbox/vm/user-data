#cloud-config

hostname: claude-sandbox
manage_etc_hosts: true

users:
  - name: claude
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    # password: claude (hashed)
    passwd: $6$rounds=4096$saltsalt$ZVHgJRMVoL7grFAETjOqXk5gWCRza6CZhvbWNGOlLEIUtbpiJMCIk6FM5FRkXnQnJPlJFKMXfKI0p5JYDeSy00

packages:
  - ubuntu-desktop-minimal
  - git
  - curl
  - wget
  - ca-certificates
  - gnupg
  - spice-vdagent
  - qemu-guest-agent

runcmd:
  # Install Claude Desktop (community arm64 .deb) with retry
  - |
    for attempt in 1 2 3; do
      DEB_URL=$(curl -sL --retry 2 "https://api.github.com/repos/aaddrick/claude-desktop-debian/releases/latest" \
        | grep -o '"browser_download_url": *"[^"]*_arm64\.deb"' \
        | head -1 \
        | sed 's/"browser_download_url": *"//;s/"$//')
      if [ -n "${DEB_URL}" ]; then
        wget -q --tries=3 "${DEB_URL}" -O /tmp/claude-desktop.deb && break
      fi
      echo "Attempt ${attempt} failed, retrying in 10s..."
      sleep 10
    done
    if [ -f /tmp/claude-desktop.deb ]; then
      apt-get install -y /tmp/claude-desktop.deb
      rm -f /tmp/claude-desktop.deb
    else
      echo "WARNING: Claude Desktop installation failed after 3 attempts"
    fi

  # Auto-login claude user
  - |
    mkdir -p /etc/gdm3
    cat > /etc/gdm3/custom.conf << 'GDMEOF'
    [daemon]
    AutomaticLoginEnable=true
    AutomaticLogin=claude
    [security]
    [xdmcp]
    [chooser]
    [debug]
    GDMEOF

  # Create desktop shortcut
  - |
    mkdir -p /home/claude/Desktop
    cp /usr/share/applications/claude-desktop.desktop /home/claude/Desktop/ 2>/dev/null || true
    chown -R claude:claude /home/claude

  # Enable GUI on boot
  - systemctl set-default graphical.target
  - systemctl enable gdm3

  # Reboot to start GUI
  - reboot

final_message: "Claude sandbox VM ready after $UPTIME seconds"
