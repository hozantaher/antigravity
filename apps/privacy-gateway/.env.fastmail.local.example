# Copy this file to `.env.fastmail.local` and replace every `REPLACE_...` value.
# Do not commit the real `.env.fastmail.local`.
#
# Mailbox roles:
# - FASTMAIL_GATEWAY_ADDRESS: the Fastmail account used by the gateway for SMTP and IMAP auth
# - RECIPIENT_MAILBOX_ADDRESS: the separate mailbox where you manually confirm outbound delivery
# - INBOUND_TEST_MAILBOX_ADDRESS: the mailbox the gateway syncs from over IMAP
#
# Recommended first run:
# - FASTMAIL_GATEWAY_ADDRESS == INBOUND_TEST_MAILBOX_ADDRESS
# - RECIPIENT_MAILBOX_ADDRESS is a separate mailbox

LISTEN_ADDR=:8080
ALIAS_DOMAIN=REPLACE_ALIAS_DOMAIN
DATA_DIR=./data
DATA_ENCRYPTION_KEY_B64=REPLACE_BASE64_32_BYTE_KEY

DELIVERY_MODE=smtp

# Fastmail provider settings
SMTP_HOST=smtp.fastmail.com
SMTP_PORT=587
SMTP_USERNAME=REPLACE_FASTMAIL_GATEWAY_ADDRESS
SMTP_PASSWORD=REPLACE_FASTMAIL_APP_PASSWORD
SMTP_HELLO_DOMAIN=REPLACE_SMTP_HELLO_DOMAIN
SMTP_REQUIRE_STARTTLS=true
SMTP_CONNECT_TIMEOUT_SECONDS=10

IMAP_HOST=imap.fastmail.com
IMAP_PORT=993
IMAP_USERNAME=REPLACE_INBOUND_TEST_MAILBOX_ADDRESS
IMAP_PASSWORD=REPLACE_FASTMAIL_APP_PASSWORD
IMAP_TIMEOUT_SECONDS=10

MAX_RECIPIENTS=10
MAX_MESSAGE_BYTES=131072

DEV_API_TOKEN=dev-token
INTAKE_API_TOKEN=
DEV_USER_ID=user-dev
DEV_TENANT_ID=tenant-dev
DEV_USER_EMAIL=REPLACE_FASTMAIL_GATEWAY_ADDRESS

# Operator-only values for the live run sheet and manual verification.
# These are not consumed by the app directly, but keeping them here helps avoid confusion.
FASTMAIL_GATEWAY_ADDRESS=REPLACE_FASTMAIL_GATEWAY_ADDRESS
RECIPIENT_MAILBOX_ADDRESS=REPLACE_RECIPIENT_MAILBOX_ADDRESS
INBOUND_TEST_MAILBOX_ADDRESS=REPLACE_INBOUND_TEST_MAILBOX_ADDRESS
