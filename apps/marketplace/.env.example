# Copy to .env and fill in. The real .env is gitignored.

# Postgres connection string (Railway/Supabase/local).
#   local dev: postgresql://user:pass@localhost:5432/garaaage_auction
POSTGRES_URL=
# Set to "disable" for local/non-SSL Postgres. Default enables SSL with
# rejectUnauthorized:false (works with the Railway proxy's self-signed cert).
# POSTGRES_SSL=disable
# Per-statement timeout (ms) on the request-path pool; default 15000. The CLI scripts
# (migrate/seed/import) set 0 themselves so long index builds aren't cancelled.
# POSTGRES_STATEMENT_TIMEOUT=15000

# Firebase Admin (server): path to a service account JSON for the project.
# On Firebase App Hosting this is unset — the Admin SDK uses ADC instead.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firebase Web config (Project settings → Your apps → Web → SDK setup).
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Local auth testing against the Firebase emulator (optional, dev/test only):
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# HMAC pepper for admin-issued API tokens (third-party API access). Unset → the
# admin "API Tokens" section is hidden and token creation returns 500. Generate:
#   openssl rand -hex 32
INTERNAL_API_SECRET=

# Shared secret for the close-auctions cron endpoint (/api/cron/close-auctions).
# Google Cloud Scheduler sends it as `Authorization: Bearer <secret>`. Unset → the
# endpoint returns 503. Generate: openssl rand -hex 32
CRON_SECRET=

# Inbox that public contact-form submissions and price offers are e-mailed to. Unset →
# falls back to COMPANY.email (info@auction24.cz). Needs SENDGRID_API_KEY for delivery;
# the message is persisted to the database either way.
CONTACT_NOTIFY_EMAIL=
