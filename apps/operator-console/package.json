{
  "name": "operator-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "dev": "vite --port 18175",
    "dev:full": "concurrently \"vite --port 18175\" \"node --watch --env-file-if-exists=.env server.js\"",
    "dev:bff": "node --watch --env-file-if-exists=.env server.js",
    "start": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "test": "TEST_SCOPE=all vitest run",
    "test:fast": "vitest run",
    "test:contract": "TEST_SCOPE=contract vitest run",
    "test:integration": "TEST_SCOPE=integration vitest run",
    "test:full": "TEST_SCOPE=all vitest run",
    "test:all": "TEST_SCOPE=all vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:load": "node scripts/load.mjs",
    "tools:explain": "node scripts/explain.mjs",
    "test:explain-gate": "node scripts/explain-gate.mjs",
    "test:bundle": "node scripts/bundle.mjs",
    "test:lighthouse": "node scripts/lighthouse.mjs",
    "test:security": "node scripts/security.mjs",
    "test:flaky": "node scripts/flaky.mjs",
    "tools:shadow": "node scripts/shadow-capture.mjs",
    "test:linkage": "node scripts/test-prod-linkage.mjs",
    "test:density": "node scripts/assertion-density.mjs",
    "test:fixture-drift": "node scripts/fixture-prod-diff.mjs",
    "tools:snapshot": "node scripts/prod-snapshot-capture.mjs",
    "test:inverted-fault": "node scripts/inverted-fault-harness.mjs",
    "test:hallucination": "node scripts/test-prod-linkage.mjs && node scripts/assertion-density.mjs && node scripts/hallucination-score.mjs",
    "tools:hallucination-baseline": "node scripts/hallucination-score.mjs && cp hallucination-score.json hallucination-score.baseline.json",
    "kpi": "node scripts/kpi.mjs",
    "kpi:snapshot": "node scripts/kpi-snapshot.mjs",
    "kpi:baseline": "node scripts/kpi-snapshot.mjs --baseline",
    "health": "node scripts/health.js",
    "health:json": "node scripts/health.js --json",
    "scorecard": "node --env-file-if-exists=.env scripts/run-scorecard.mjs",
    "scorecard:json": "node --env-file-if-exists=.env scripts/run-scorecard.mjs --json",
    "scorecard:log": "node --env-file-if-exists=.env scripts/run-scorecard.mjs --log",
    "scorecard:diff": "node --env-file-if-exists=.env scripts/run-scorecard.mjs --diff",
    "report": "node --env-file-if-exists=.env scripts/system-report.mjs",
    "report:json": "node --env-file-if-exists=.env scripts/system-report.mjs --json",
    "sentinel": "node --env-file-if-exists=.env scripts/sentinel-monitor.mjs",
    "audit:classifier-sample": "node --env-file-if-exists=.env ../../scripts/audits/classifier-accuracy.mjs",
    "audit:classifier-score": "node ../../scripts/audits/classifier-score.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.0.0",
    "express-fileupload": "^1.5.2",
    "firebase": "^12.15.0",
    "isomorphic-dompurify": "^3.12.0",
    "pg": "^8.13.0",
    "socks": "^2.8.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@sentry/react": "^10.50.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@stryker-mutator/api": "^9.6.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autocannon": "^8.0.0",
    "axe-core": "^4.11.3",
    "chrome-launcher": "^1.2.1",
    "concurrently": "^9.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^25.0.0",
    "knip": "^6.4.1",
    "lighthouse": "^13.1.0",
    "lucide-react": "^0.525.0",
    "msw": "^2.13.4",
    "pg-mem": "^3.0.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "vite": "^7.3.2",
    "vitest": "^2.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  }
}