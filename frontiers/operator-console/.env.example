# Express BFF port (default: 3100)
PORT=3100

# Go outreach backend URL
GO_SERVER_URL=http://localhost:8080

# API key must match OUTREACH_API_KEY in the Go service
OUTREACH_API_KEY=change-me

# CORS origin for Vite dev server
CORS_ORIGIN=http://localhost:5175

# Sentry error monitoring (optional — omit to disable)
# Create projects at sentry.io → Settings → Projects → New Project
SENTRY_DSN_BFF=
VITE_SENTRY_DSN_FRONTEND=

# Source map upload (optional — needed only for production builds)
# Get token: sentry.io → Settings → Auth Tokens → Create New Token (scope: project:releases)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT_FRONTEND=

# Dashboard authentication (AW-F1, 2026-05-20).
# Default disabled — set DASHBOARD_AUTH_ENABLED=true after running
# `node scripts/set-dashboard-password.js` to generate DASHBOARD_PASS_HASH.
# DASHBOARD_USER is the username; DASHBOARD_PASS_HASH is the bcrypt hash
# (cost 12) printed by the CLI. Never paste a plaintext password here.
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USER=
DASHBOARD_PASS_HASH=
