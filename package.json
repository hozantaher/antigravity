{
  "name": "antigravity",
  "version": "1.4.0",
  "description": "",
  "main": "dist/index.js",
  "bin": {
    "antigravity": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run test && tsc && npm run ag:map && node dist/index.js map --gravity && node dist/index.js map --glossary && node dist/index.js docs && npm run ag:audit && npm run notify",
    "start": "ts-node src/index.ts",
    "test": "vitest run src",
    "ag:audit": "node dist/index.js audit",
    "ag:heal": "node dist/index.js heal",
    "ag:jules": "node dist/index.js jules",
    "ag:map": "node dist/index.js map && node dist/index.js map --gravity",
    "changelog": "ts-node scripts/changelog.ts",
    "notify": "ts-node scripts/notify.ts",
    "release": "standard-version",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bullmq": "^5.79.2",
    "cheerio": "^1.2.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.45.0",
    "react": "^18.3.1",
    "runpod-sdk": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "spine/**/*.{ts,vue,js,json}": [
      "npm run ag:jules",
      "npm run build",
      "npm run ag:heal",
      "npm run ag:audit"
    ]
  }
}
