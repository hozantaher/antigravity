# Antigravity — šablona prostředí. NIKDY sem nedávej skutečné klíče (tento soubor se commituje).
# Zkopíruj na .env (gitignored) a vyplň.

# ── RunPod LLM (GPU pod, OpenAI-kompatibilní inference) ───────────────────────
# RunPod account API key (GraphQL provisioning podů). Formát rpa_...
# Čteno přes process.env.RUNPOD_API_KEY (vzor spine/.../parser-compiler/compiler.ts).
RUNPOD_API_KEY=
# Inference endpoint (OpenAI-kompatibilní /v1). Když prázdné, runtime čte proxy URL
# z /tmp/runpod_llm_url (zapisuje ho scripts/setup-pod-llm.ts).
RUNPOD_URL=
# Model běžící na podu.
LLM_MODEL=qwen2.5:14b-instruct
# Perzistentní RunPod Network Volume → cache modelů (/root/.ollama) přežije teardown podu,
# takže se model nestahuje při každém běhu. Volume je region-locked → pod běží v jeho DC.
RUNPOD_VOLUME_ID=
RUNPOD_VOLUME_DC=

# ── Fallback LLM providers (volitelné) ───────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
